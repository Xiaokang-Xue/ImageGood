flowchart TB
    subgraph Entry["访问层"]
      direction LR
      Client["用户浏览器 / 移动端"] --> Edge["Nginx + HTTPS"] --> Next["Next.js App Router<br/>Route Handlers"]
    end

    subgraph Services["业务服务"]
      direction LR
      Auth["账号与鉴权"]
      Image["图片任务"]
      Billing["订单与积分"]
      Ops["管理与运营"]
      Auth ~~~ Image ~~~ Billing ~~~ Ops
    end

    Next --> Auth
    Next --> Image
    Next --> Billing
    Next --> Ops

    subgraph Infrastructure["基础设施适配"]
      direction LR
      Data[("MySQL / 本地 JSON<br/>数据层")]
      Files[("腾讯云 COS / 本地<br/>图片存储")]
      Models["OpenAI / Codex<br/>图片 Provider"]
      Pay["微信支付 / 支付宝"]
      Message["阿里云短信 / SMTP<br/>飞书机器人"]
      Data ~~~ Files ~~~ Models ~~~ Pay ~~~ Message
    end

    Auth --> Data
    Auth --> Message
    Image --> Data
    Image --> Files
    Image --> Models
    Billing --> Data
    Billing --> Pay
    Ops --> Data
    Ops --> Message

    Checks["冒烟测试 · 质量基线 · 任务巡检"] -. "验证与观测" .-> Next
    Checks -.-> Image
    Checks -.-> Ops

