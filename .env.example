# ============================================================
# ImageGood environment example
# Copy this file to .env.local and fill only the values you need.
# Do not commit .env.local, API keys, payment keys, certificates, or passwords.
# ============================================================

# ------------------------------------------------------------
# App / Auth
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://imagegood.huoideas.com
AUTH_SECRET="please-change-this-secret"
AUTH_COOKIE_SECURE=false

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Local development file database:
DATABASE_URL="file:./dev.db"

# Production MySQL example:
# DATABASE_URL="mysql://imagegood:your-password@rm-2ze743c70lk0ea1s22o.mysql.rds.aliyuncs.com:3306/image_good?connection_limit=5"
MYSQL_CONNECTION_LIMIT=5

# ------------------------------------------------------------
# Email / SMTP
# ------------------------------------------------------------
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ImageGood <noreply@huoideas.com>"
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# ------------------------------------------------------------
# Aliyun SMS
# Configure SMS signature and template in Alibaba Cloud SMS console.
# AccessKey values are server-only secrets.
# ------------------------------------------------------------
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
SMS_CODE_EXPIRE_MINUTES=5
SMS_CODE_RESEND_SECONDS=60

# ------------------------------------------------------------
# Feishu operations report
# FEISHU_BOT_WEBHOOK is a secret; keep the real value only in .env.local.
# FEISHU_DAILY_REPORT_RANGE supports yesterday / today.
# ------------------------------------------------------------
FEISHU_BOT_WEBHOOK=
FEISHU_BOT_SECRET=
FEISHU_DAILY_REPORT_RANGE=yesterday

# ------------------------------------------------------------
# Payment common
# PAYMENT_MODE=mock: local payment debugging
# PAYMENT_MODE=real: real WeChat Pay / Alipay
# ------------------------------------------------------------
PAYMENT_PROVIDER=alipay
PAYMENT_MODE=mock
ENABLE_PAYMENT_TEST_PACKAGE=false

# ------------------------------------------------------------
# WeChat Pay APIv3
# ------------------------------------------------------------
WECHAT_PAY_APPID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PLATFORM_CERT_SERIAL_NO=
WECHAT_PAY_PLATFORM_CERT_PATH=
WECHAT_PAY_NOTIFY_URL=

# ------------------------------------------------------------
# Alipay page pay
# Current implementation uses public-key mode. Certificate path values
# are reserved for future certificate-mode support and can stay empty.
# ------------------------------------------------------------
ALIPAY_ENABLED=true
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_NOTIFY_URL=https://imagegood.huoideas.com/api/payment/alipay/notify
ALIPAY_RETURN_URL=https://imagegood.huoideas.com/checkout/alipay/return
ALIPAY_APP_CERT_PATH=
ALIPAY_ALIPAY_PUBLIC_CERT_PATH=
ALIPAY_ROOT_CERT_PATH=

# ------------------------------------------------------------
# Image generation
# IMAGE_PROVIDER=openai: call OpenAI-compatible Images API
# IMAGE_PROVIDER=codex: call local Python Codex image service
# ------------------------------------------------------------
IMAGE_API_MODE=real
IMAGE_PROVIDER=openai
IMAGE_MODEL=gpt-image-2

# OpenAI-compatible Images API
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Python Codex image service, only needed when IMAGE_PROVIDER=codex
CODEX_IMAGE_API_BASE_URL=http://127.0.0.1:8000
CODEX_IMAGE_API_TIMEOUT_SECONDS=900
CODEX_IMAGE_API_WORKDIR=/data/codex_image_api_runs
CODEX_RESULT_GRACE_SECONDS=900
CODEX_MODEL=

# ------------------------------------------------------------
# Image storage
# IMAGE_STORAGE_PROVIDER=local: local server files
# IMAGE_STORAGE_PROVIDER=cos: Tencent Cloud COS
# ------------------------------------------------------------
IMAGE_STORAGE_PROVIDER=local

# Tencent Cloud COS
TENCENT_COS_ENABLED=false
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-beijing
TENCENT_COS_BUCKET=
TENCENT_COS_KEY_PREFIX=imageGood

# Leave empty to serve COS images through /api/storage/images/... with login protection.
# Set a CDN or public bucket domain if the bucket is public-readable.
TENCENT_COS_PUBLIC_BASE_URL=
TENCENT_COS_USE_PROXY=true

# Optional: after COS upload and DB success, remove only /data/codex_image_api_runs/tasks/{taskId}.
TENCENT_COS_CLEAN_LOCAL_TASK_DIR=false
